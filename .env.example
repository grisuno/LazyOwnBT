# =========================================================================
# LazyOwnBT — Variables de entorno (plantilla)
# =========================================================================
# Copia este archivo a `.env` y rellena los valores.
# NUNCA subas `.env` al repositorio (debe estar en .gitignore).
# =========================================================================

# --- Entorno ------------------------------------------------------------
# production | development | testing
FLASK_ENV=development

# --- Bind de la aplicación web ----------------------------------------
LAZYOWN_BIND=127.0.0.1
LAZYOWN_PORT=5000

# --- JWT ----------------------------------------------------------------
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Mínimo 32 bytes. En producción, OBLIGATORIO.
JWT_SECRET_KEY=changeme-please-generate-a-64-char-secret-xxxxxxxxxxxxxxxxxx

# --- Usuario admin ------------------------------------------------------
# Opción A: contraseña en plano (se hashea al arrancar)
ADMIN_PASSWORD=changeme
# Opción B: hash bcrypt ya generado (recomendado en producción)
# ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Base de datos ------------------------------------------------------
LAZYOWN_DB_PATH=./lazyown.db

# --- Timeouts -----------------------------------------------------------
LAZYOWN_COMMAND_TIMEOUT=30

# --- Llaves adicionales que el SecretsFilter redacta en logs -----------
# API_TOKEN=
# OLLAMA_API_KEY=
# DB_PASSWORD=
